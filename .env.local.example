# Variáveis de ambiente — copie para .env.local
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# URL pública do app (produção). Em local pode omitir (usa localhost).
# Na Vercel: https://mesa-tormenta20.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

